# Dependencies
node_modules/

# Build output
.next/
out/
dist/
build/

# Environment files — NEVER include in image
# (The previous version had `.env.\*` with an escaped asterisk — Docker treats
# `\*` as a literal `*` character, so variants like `.env.production` were NOT
# being excluded. Fixed 2026-05-12.)
.env
.env.*
!.env.example

