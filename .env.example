# =============================================================================
# Parametric Memory Web — Environment Variables
# =============================================================================
# Copy to .env.local for local development.
# In production, set via docker-compose.yml environment section.
# NEVER commit .env or .env.local to git.
# =============================================================================

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- GitHub Webhooks ---
GITHUB_WEBHOOK_SECRET=your-webhook-secret
DOCS_WEBHOOK_SECRET=your-docs-webhook-secret

# --- Email (Resend) ---
RESEND_API_KEY=re_...
CONTACT_EMAIL=entityone22@gmail.com

# --- Build Info (set by CI/CD) ---
GIT_COMMIT_SHA=local

# --- MMPM Memory Server (Substrate Viewer) ---
# The MMPM server supports two API key scopes:
#   - master (MMPM_API_KEY)       → full read/write, used by server-side MCP
#   - read-only (MMPM_VIZ_API_KEY) → read-only, no side-effects, used by viz proxy
#
# The Substrate Viewer proxy prefers MMPM_VIZ_API_KEY (safe for public-facing).
# Falls back to MMPM_API_KEY if viz key is not set.
MMPM_API_URL=https://mmpm.co.nz
MMPM_API_KEY=your-mmpm-master-key-here
MMPM_VIZ_API_KEY=your-mmpm-read-only-key-here
CORS_ORIGIN=https://parametric-memory.dev

# --- Compute Backend ---
# Base URL of the mmpm-compute HTTP API. Dev default keeps us local.
# Prod should point at https://memory.kiwi or equivalent.
MMPM_COMPUTE_URL=http://localhost:3100

# --- OAuth Phase 2 (ADR-003) ---
# Feature flag. When false, every OAuth code path is a no-op
# (endpoints 404, LoginClient hides provider buttons). When true,
# at least one provider pair must be fully populated below AND
# COMPUTE_OAUTH_BRIDGE_SIGNING_KEY must be >= 32 chars.
AUTH_OAUTH_ENABLED=false

# HMAC-SHA256 shared secret with compute. Must be identical to
# COMPUTE_OAUTH_BRIDGE_SIGNING_KEY on the compute host. Rotate both
# halves in the same deploy window. Generate: `openssl rand -hex 32`.
COMPUTE_OAUTH_BRIDGE_SIGNING_KEY=your-shared-32-plus-char-secret

# Google OAuth 2.0 client. Dev redirect URI:
#   http://localhost:3000/api/auth/oauth/google/callback
# Prod redirect URI:
#   https://parametric-memory.dev/api/auth/oauth/google/callback
# Set BOTH halves or NEITHER — half-configured throws at boot.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth App. One app per environment (GitHub allows only one
# callback URL per app, so dev and prod are separate apps). Same
# both-or-neither rule.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Absolute base URL the website serves from. Used to build the
# redirect_uri handed to providers. Must match what's registered
# with each provider exactly. No trailing slash. Dev: localhost.
PUBLIC_SITE_URL=http://localhost:3000
