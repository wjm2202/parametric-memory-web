# =============================================================================
# Parametric Memory Web — Environment Variables
# =============================================================================
# Copy to .env.local for local development.
# In production, set via docker-compose.yml environment section.
# NEVER commit .env or .env.local to git.
# =============================================================================

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- GitHub Webhooks ---
GITHUB_WEBHOOK_SECRET=your-webhook-secret
DOCS_WEBHOOK_SECRET=your-docs-webhook-secret

# --- Email (Resend) ---
RESEND_API_KEY=re_...
CONTACT_EMAIL=entityone22@gmail.com

# --- Build Info (set by CI/CD) ---
GIT_COMMIT_SHA=local

# --- MMPM Memory Server (Substrate Viewer) ---
# The MMPM server supports two API key scopes:
#   - master (MMPM_API_KEY)       → full read/write, used by server-side MCP
#   - read-only (MMPM_VIZ_API_KEY) → read-only, no side-effects, used by viz proxy
#
# The Substrate Viewer proxy prefers MMPM_VIZ_API_KEY (safe for public-facing).
# Falls back to MMPM_API_KEY if viz key is not set.
MMPM_API_URL=https://mmpm.co.nz
MMPM_API_KEY=your-mmpm-master-key-here
MMPM_VIZ_API_KEY=your-mmpm-read-only-key-here
CORS_ORIGIN=https://parametric-memory.dev
