{
  "name": "parametric-memory-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.4",
  "description": "Commercial website, documentation, and developer portal for Parametric Memory",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "rm -rf .next/types && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate-docs": "tsx scripts/generate-docs.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "guard:testids": "node scripts/check-testids.mjs --quiet",
    "guard:actions": "node scripts/check-actions-manifest.mjs --quiet",
    "guard:all": "npm run guard:testids && npm run guard:actions && npm run guard:llms-txt",
    "preflight": "npm run format && npm run lint && npm run typecheck && npm run guard:all && npm run test && npm run build",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --project=public",
    "e2e:authed": "playwright test --project=authed",
    "e2e:auth": "playwright test --project=setup",
    "e2e:headless": "playwright test --headed=false",
    "e2e:debug": "PWDEBUG=1 playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:local": "E2E_BASE_URL=http://localhost:3000 playwright test",
    "build:llms-txt": "tsx scripts/build-llms-txt.ts",
    "guard:llms-txt": "tsx scripts/build-llms-txt.ts --check"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@stripe/stripe-js": "^5.0.0",
    "@types/three": "^0.184.0",
    "clsx": "^2.1.0",
    "d3": "^7.9.0",
    "d3-force-3d": "^3.0.6",
    "framer-motion": "^12.0.0",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "next": "^15.2.0",
    "next-mdx-remote": "^6.0.0",
    "postprocessing": "^6.38.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-pretty-code": "^0.14.3",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.0",
    "shiki": "^3.0.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.0.0",
    "three": "^0.184.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3": "^7.4.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "author": "G. Osborne <entityone22@gmail.com>",
  "license": "SEE LICENSE IN LICENSE"
}
